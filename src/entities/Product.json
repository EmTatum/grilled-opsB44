{
  "name": "Product",
  "type": "object",
  "properties": {
    "product_name": {
      "type": "string",
      "title": "Product Name"
    },
    "category": {
      "type": "string",
      "title": "Category",
      "enum": [
        "Cannabis — Standard",
        "Cannabis — Premium",
        "In-Store Goods",
        "Concierge Items"
      ]
    },
    "retail_price": {
      "type": "number",
      "title": "Retail Price (R)",
      "default": 0
    },
    "wholesale_price": {
      "type": "number",
      "title": "Wholesale Price (R)",
      "default": 0
    },
    "unit_of_measure": {
      "type": "string",
      "title": "Unit",
      "enum": [
        "Per Unit",
        "Per Gram",
        "Per Bag",
        "Per Bottle",
        "Per Pack"
      ],
      "default": "Per Unit"
    },
    "product_description": {
      "type": "string",
      "title": "Description"
    },
    "internal_notes": {
      "type": "string",
      "title": "Internal Notes"
    },
    "product_status": {
      "type": "string",
      "title": "Status",
      "enum": [
        "Active",
        "Inactive",
        "Seasonal",
        "Coming Soon"
      ],
      "default": "Active"
    },
    "supplier": {
      "type": "string",
      "title": "Source"
    },
    "last_stock_count": {
      "type": "number",
      "title": "Last Stock Count",
      "default": 0
    },
    "new_stock_arrived": {
      "type": "number",
      "title": "New Stock Arrived",
      "default": 0
    },
    "current_stock": {
      "type": "number",
      "title": "Current Stock",
      "default": 0
    },
    "low_stock_threshold": {
      "type": "number",
      "title": "Low Stock Threshold",
      "default": 5
    }
  },
  "required": [
    "product_name",
    "category",
    "retail_price",
    "unit_of_measure",
    "product_status",
    "last_stock_count",
    "new_stock_arrived",
    "current_stock"
  ],
  "rls": {
    "create": {
      "user_condition": {
        "role": "admin"
      }
    },
    "read": null,
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}
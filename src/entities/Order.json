{
  "name": "Order",
  "type": "object",
  "properties": {
    "client_name": {
      "type": "string",
      "title": "Client Name"
    },
    "order_details": {
      "type": "string",
      "title": "Items Summary"
    },
    "order_value": {
      "type": "number",
      "title": "Order Value",
      "default": 0
    },
    "time_slot": {
      "type": "string",
      "title": "Time Slot"
    },
    "payment_method": {
      "type": "string",
      "title": "Payment Method",
      "enum": [
        "Cash",
        "Card",
        "Bank Transfer",
        "Credit on Account",
        "Other"
      ]
    },
    "payment_status": {
      "type": "string",
      "title": "Payment Status",
      "enum": [
        "PAID",
        "CASH",
        "PENDING"
      ],
      "default": "PENDING"
    },
    "delivery_address": {
      "type": "string",
      "title": "Delivery Address"
    },
    "special_instructions": {
      "type": "string",
      "title": "Special Instructions"
    },
    "priority_level": {
      "type": "string",
      "title": "Priority Level",
      "enum": [
        "Low",
        "Medium",
        "High"
      ],
      "default": "Medium"
    },
    "planner_status": {
      "type": "string",
      "title": "Planner Status",
      "enum": [
        "Pending",
        "Processing",
        "Ready",
        "Dispatched"
      ],
      "default": "Pending"
    },
    "source_report_id": {
      "type": "string",
      "title": "Source Report ID"
    },
    "order_date": {
      "type": "string",
      "format": "date-time",
      "title": "Order Date & Time"
    },
    "status": {
      "type": "string",
      "enum": [
        "Pending",
        "Confirmed",
        "Fulfilled",
        "Cancelled"
      ],
      "title": "Status"
    }
  },
  "required": [
    "client_name",
    "order_details",
    "order_date",
    "status"
  ],
  "rls": {
    "create": null,
    "read": null,
    "update": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    }
  }
}